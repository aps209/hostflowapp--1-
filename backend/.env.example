# Copia este archivo a backend/.env (o a ./.env en la raiz) y rellena los valores.
# Las variables no definidas usan los defaults de app/core/config.py.

# --- IA (Gemini) ---
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash

# --- Base de datos / Auth ---
# DATABASE_URL=postgresql+psycopg://hostflow:hostflow@postgres:5432/hostflow
JWT_SECRET_KEY=change-me-in-env

# --- Google Places (reseñas) ---
GOOGLE_PLACES_API_KEY=

# --- Twilio (SMS, canal alternativo de recordatorios) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# URL publica usada en los enlaces de confirmar/cancelar (fallback web)
PUBLIC_APP_URL=http://localhost:5173

# --- WhatsApp Cloud API (Meta) ---
# Phone Number ID del numero registrado en tu WhatsApp Business Account (WABA)
WHATSAPP_PHONE_NUMBER_ID=
# Token PERMANENTE de un System User con permisos whatsapp_business_messaging + whatsapp_business_management
WHATSAPP_ACCESS_TOKEN=
# Token que tu inventas y configuras identico en Meta (handshake del webhook)
WHATSAPP_VERIFY_TOKEN=
# App Secret de la Meta App (valida la firma X-Hub-Signature-256 del webhook)
WHATSAPP_APP_SECRET=
# Version de la Graph API
WHATSAPP_API_VERSION=v21.0
# Nombre y idioma de la plantilla aprobada en Meta (body de 6 variables + 2 botones quick reply)
WHATSAPP_REMINDER_TEMPLATE=reservation_reminder
WHATSAPP_REMINDER_TEMPLATE_LANG=es

# --- Scheduler de recordatorios ---
# Zona horaria para comparar el send_time configurado por restaurante
REMINDER_TIMEZONE=Europe/Madrid
# Poner en false para desactivar el scheduler in-process (p.ej. si corres varios workers)
RUN_SCHEDULER=true
